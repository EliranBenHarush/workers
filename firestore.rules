rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Jobs: anyone can create, only authenticated can read
    match /jobs/{jobId} {
      allow create: if request.resource.data.keys().hasAll(['name', 'phone', 'category', 'city', 'description', 'status', 'createdAt']);
      allow read: if request.auth != null;
      allow update, delete: if false;
    }

    // Professionals: can only read/write their own doc
    match /professionals/{userId} {
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null;
      allow delete: if false;
    }

    // Interests: authenticated professionals can create, read their own
    match /interests/{interestId} {
      allow create: if request.auth != null
        && request.resource.data.professionalId == request.auth.uid;
      allow read: if request.auth != null
        && (resource.data.professionalId == request.auth.uid);
      allow update, delete: if false;
    }
  }
}
